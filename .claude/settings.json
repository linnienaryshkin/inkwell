{
  "permissions": {
    "deny": [
      "Skill(codemie:codemie-commit)",
      "Skill(msgraph)",
      "Skill(claude-setup-audit)",
      "Skill(report-issue)"
    ],
    "allow": [
      "mcp__playwright__execute-code",
      "mcp__playwright__get-screenshot",
      "mcp__playwright__init-browser",
      "mcp__github__list_issues",
      "mcp__github__search_issues",
      "Bash(npm run:*)",
      "Bash(npm audit:*)",
      "Bash(make *)",
      "Bash(uv *)",
      "Bash(task *)"
    ]
  },
  "model": "haiku",
  "statusLine": {
    "type": "command",
    "command": "sh .claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "report-issue@codemie-ai": false,
    "claude-setup-audit@codemie-ai": false,
    "msgraph@codemie-ai": false,
    "codemie-commit@codemie-ai": false,
    "codemie@codemie-ai": false
  },
  "alwaysThinkingEnabled": false,
  "effortLevel": "low",
  "autoMemoryEnabled": false,
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "terminal-notifier -message \"Claude has finished\" -title \"Claude Code\" 2>/dev/null || true"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "msg=$(jq -r '.message // \"Claude needs your input\"' 2>/dev/null); terminal-notifier -message \"$msg\" -title \"Claude Code\" 2>/dev/null || true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "input=$(cat); repo=$(git rev-parse --show-toplevel 2>/dev/null); if [ -n \"$repo\" ] && echo \"$input\" | jq -r '.. | strings' 2>/dev/null | grep -qE \"${repo}(/.*)?\\.env($|[^.])\"; then echo 'Access to .env file is not allowed.' >&2; exit 2; fi"
          }
        ]
      }
    ]
  }
}
