#!/bin/bash
# .dev-env - Load environment variables for Claude Code development
#
# Usage:
#   source .dev-env
#   claude  # Now runs with GITHUB_TOKEN set
#
# Or in one line:
#   source .dev-env && claude

set -e

# Get the directory where this script is located
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Check if .env exists
if [ ! -f "$SCRIPT_DIR/.env" ]; then
  echo "❌ Error: .env file not found"
  echo ""
  echo "Setup Instructions:"
  echo "1. Copy template: cp .env.example .env"
  echo "2. Edit .env and add your GITHUB_TOKEN"
  echo "3. Run: source .dev-env"
  return 1 2>/dev/null || exit 1
fi

# Load environment variables from .env
export $(grep -v '^#' "$SCRIPT_DIR/.env" | grep -v '^$' | xargs)

# Validate required variables
if [ -z "$GITHUB_TOKEN" ]; then
  echo "❌ Error: GITHUB_TOKEN is not set in .env"
  return 1 2>/dev/null || exit 1
fi

# Validate token format (GitHub tokens start with ghp_, ghu_, ghs_, or gho_)
if ! echo "$GITHUB_TOKEN" | grep -qE '^(ghp_|ghu_|ghs_|gho_)'; then
  echo "⚠️  Warning: GITHUB_TOKEN doesn't appear to be a valid GitHub token format"
  echo "   Valid tokens start with: ghp_, ghu_, ghs_, or gho_"
fi

echo "✅ Environment loaded successfully"
echo "   • GITHUB_TOKEN: ${GITHUB_TOKEN:0:5}... (length: ${#GITHUB_TOKEN})"
echo ""
echo "Ready to run: claude"
