# This file is fully repeating the .env file, but with empty values. You can copy this file to .env and fill in the values to use it.

LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=langchain-py-essentials
# If you are on the EU instance:
LANGSMITH_ENDPOINT=https://eu.api.smith.langchain.com

ANTHROPIC_API_KEY=

# https://github.com/langchain-ai/lca-langchainV1-essentials
GITHUB_TOKEN=

# GitHub OAuth app credentials (for local dev; CI uses placeholders from this file)
OAUTH_CLIENT_ID=ci-placeholder
OAUTH_CLIENT_SECRET=ci-placeholder
OAUTH_CALLBACK_URL=http://localhost:8000/auth/callback
SESSION_SECRET=ci-placeholder-secret